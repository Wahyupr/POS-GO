# Server
PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=yourdbname
DB_SSLMODE=disable

# JWT
JWT_SECRET=ganti_dengan_secret_yang_panjang_dan_random
JWT_ACCESS_EXP_MINUTES=15
JWT_REFRESH_EXP_DAYS=7

# Google OAuth (opsional — kosongkan jika tidak pakai Google Login)
GOOGLE_CLIENT_ID=
